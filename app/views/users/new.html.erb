<div style="max-width: 600px; margin: 40px auto; font-family: sans-serif;">
  <h2>Criar uma Conta</h2>

  <% if @user.errors.any? %>
    <div style="color: red; margin-bottom: 20px;">
      <ul>
        <% @user.errors.full_messages.each do |mensagem| %>
          <li><%= mensagem %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @user, url: users_path, local: true do |f| %>
    
    <div style="margin-bottom: 10px;">
      <%= f.label :name, "Nome" %><br>
      <%= f.text_field :name, required: true %>
    </div>

    <div style="margin-bottom: 10px;">
      <%= f.label :last_name, "Sobrenome" %><br>
      <%= f.text_field :last_name, required: true %>
    </div>

    <div style="margin-bottom: 10px;">
      <%= f.label :email, "E-mail" %><br>
      <%= f.email_field :email, required: true %>
    </div>

    <div style="margin-bottom: 10px;">
      <%= f.label :password, "Senha" %><br>
      <%= f.password_field :password, required: true %>
    </div>

    <div style="margin-bottom: 10px;">
      <%= f.label :birthdate, "Data de Nascimento" %><br>
      <%= f.date_field :birthdate, required: true %>
    </div>

    <div style="margin-bottom: 20px;">
      <%= f.label :gender, "Gênero" %><br>
      <%= f.select :gender, ['Masculino', 'Feminino', 'Não Binário'], prompt: "Selecione..." %>
    </div>

    <%= f.submit "Cadastrar", style: "padding: 10px; cursor: pointer;" %>
  <% end %>

  <p style="margin-top: 20px;">
    Já tem uma conta? <%= link_to "Faça Login aqui", root_path %>
  </p>
</div>