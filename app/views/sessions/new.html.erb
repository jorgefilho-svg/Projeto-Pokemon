<div style="max-width: 600px; margin: 40px auto; font-family: sans-serif;">
  <h2>Login</h2>

  <% if flash[:notice] %>
    <div style="color: green; margin-bottom: 20px;"><%= flash[:notice] %></div>
  <% end %>

  <% if flash[:alert] %>
    <div style="color: red; margin-bottom: 20px;"><%= flash[:alert] %></div>
  <% end %>

  <%= form_with url: login_path, local: true do |f| %>
    
    <div style="margin-bottom: 10px;">
      <%= f.label :email, "E-mail" %><br>
      <%= f.email_field :email, required: true %>
    </div>

    <div style="margin-bottom: 20px;">
      <%= f.label :password, "Senha" %><br>
      <%= f.password_field :password, required: true %>
    </div>

    <%= f.submit "Entrar", style: "padding: 10px; cursor: pointer;" %>
  <% end %>

  <p style="margin-top: 20px;">
    Ainda não tem conta? <%= link_to "Registe-se aqui", cadastro_path %>
  </p>
</div>